{
  "expo": {
    "name": "シッテムの箱",
    "slug": "Shittim-Chest",
    "version": "1.0.10",
    "orientation": "default",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.hotakacchi.shittimchest",
      "buildNumber": "11",
      "infoPlist": {
        "NSCameraUsageDescription": "写真を撮影するためにカメラを使用します。",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "plugins": [
      "expo-camera",
      [
        "expo-media-library",
        {
          "photosPermission": false,
          "savePhotosPermission": "撮影した写真を端末のフォトライブラリに保存するために使用します。"
        }
      ]
    ],
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#182e42",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "98733792-6dc9-4a67-a801-fec09ecb9772"
      }
    },
    "owner": "hotakacchi",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/98733792-6dc9-4a67-a801-fec09ecb9772",
      "requestHeaders": {
        "expo-channel-name": "preview"
      }
    }
  }
}
